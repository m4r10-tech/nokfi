# ════════════════════════════════════════════════════════════
# Nokfi Backend — Variables de entorno
#
# CÓMO USAR ESTE ARCHIVO:
#   1. Copia este archivo y renómbralo a ".env" (sin el .example):
#        cp .env.example .env
#   2. Rellena cada valor vacío siguiendo las instrucciones de cada bloque
#   3. Nunca subas el archivo ".env" (ya renombrado) a GitHub ni lo compartas
#      por chat/email. El .gitignore ya está configurado para ignorarlo.
#   4. En el VPS, una vez relleno, ejecuta: chmod 600 .env
#      (esto hace que solo tu usuario pueda leer el archivo, nadie más)
# ════════════════════════════════════════════════════════════


# ── Servidor ──
# No requieren ninguna cuenta externa, son configuración propia.

PORT=3001
# Puerto donde arranca el backend. No lo cambies a menos que el 3001
# esté ocupado por otra cosa en tu VPS. Nginx redirige hacia este puerto.

NODE_ENV=production
# Déjalo en "production" en el VPS real. Solo se pone "development"
# si pruebas el backend en tu propio ordenador.


# ── Base de datos ──
# No requiere ninguna cuenta, SQLite crea el archivo solo la primera vez.

DB_PATH=./db/nokfi.db
# Ruta donde se guardará el archivo de base de datos. No lo toques
# salvo que sepas lo que haces.


# ── Seguridad: contraseña del panel admin ──

ADMIN_SECRET=
# Esta es la "contraseña" para entrar al panel de administración.
# NO la consigues en ningún sitio web — la INVENTAS tú mismo.
# Para generar una segura y aleatoria, ejecuta este comando en tu terminal:
#
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
# Copia el resultado (una cadena larga de letras y números) y pégalo aquí.
# Guárdala también en un gestor de contraseñas — si la pierdes, no hay
# forma de recuperarla, solo de generar una nueva y volver a desplegar.


# ── Dominios permitidos (CORS) ──

ALLOWED_ORIGINS=https://app.nokfi.app,https://nokfi.app
# Lista de las webs desde las que se permite llamar a este backend,
# separadas por coma SIN espacios. Sustituye "nokfi.app" por vuestro
# dominio real una vez lo compréis (sección 17 del proyecto).
# Mientras pruebes en tu ordenador, puedes poner: http://localhost:5173
#
# ⚠️ AUDITORÍA DE SEGURIDAD: el comodín "*" (permitir cualquier origen)
# SOLO funciona si NODE_ENV no es "production" — en producción el
# servidor se niega a arrancar si detecta ALLOWED_ORIGINS="*", para
# evitar que un despliegue real quede con CORS abierto a cualquier web
# por descuido. Si tu VPS tiene NODE_ENV=production, pon aquí el dominio
# o IP real desde donde sirves el frontend (ej. http://TU_IP:5173 o
# https://app.nokfi.app), nunca "*".


# ── URLs públicas (se usan dentro de los emails y en las redirecciones de pago) ──

APP_PUBLIC_URL=https://app.nokfi.app
# La URL donde vivirá la aplicación (el subdominio "app").

LANDING_PUBLIC_URL=https://nokfi.app
# La URL de la página de venta pública.


# ── Precio de la licencia ──

LICENSE_PRICE_EUR=150
# El precio en euros que cobráis por la licencia. Se usa automáticamente
# para crear el checkout de pago y para calcular los ingresos en las
# métricas del panel admin. Cambialo cuando decidáis el precio final.


# ════════════════════════════════════════════════════════════
# IA — Google Gemini
# ════════════════════════════════════════════════════════════
#
# CÓMO CONSEGUIR LA CLAVE (gratis, sin tarjeta de crédito):
#   1. Entra en https://aistudio.google.com/
#   2. Inicia sesión con una cuenta de Google (puede ser cualquiera, no
#      hace falta una cuenta de empresa)
#   3. En el menú de la izquierda, busca "Get API key" o entra
#      directamente en https://aistudio.google.com/app/apikey
#   4. Pulsa el botón "Create API key"
#   5. Te aparecerá una clave larga que empieza distinto cada vez —
#      cópiala y pégala abajo en GEMINI_API_KEY
#
# ⚠️ IMPORTANTE — decisión ya tomada y registrada en el código (ver
# routes/proxy.js): estáis usando el plan GRATUITO de Gemini. Esto
# significa que Google puede usar los datos que mandéis (los análisis
# financieros de vuestros clientes) para entrenar sus modelos, y que
# hay un límite de ~1.500 peticiones al día para todo el proyecto junto
# (no por cliente). Si en el futuro queréis evitar esto, hay que activar
# facturación en Google Cloud, lo que convierte todo en una API de pago
# (dejaría de ser gratis, pero podríais limitar el riesgo de privacidad).

GEMINI_API_KEY=

GEMINI_MODEL=gemini-2.5-flash
# Modelo a usar. "gemini-2.5-flash" es el recomendado para el free tier:
# rápido, barato/gratis, y con buena calidad para análisis de texto.
# No lo cambies a un modelo "Pro" salvo que actives facturación, porque
# los modelos Pro normalmente no están disponibles en el plan gratuito.


# ════════════════════════════════════════════════════════════
# Email transaccional — elige SOLO UNO de los dos proveedores
# ════════════════════════════════════════════════════════════

EMAIL_PROVIDER=sendgrid
# Escribe "sendgrid" o "resend" según cuál de los dos hayas configurado abajo.

EMAIL_FROM=no-reply@nokfi.app
# La dirección que aparecerá como remitente. Tiene que ser de un dominio
# que verifiques en el proveedor de email (ver instrucciones abajo).

EMAIL_FROM_NAME=Nokfi
# El nombre que verá el destinatario junto al email (ej. "Nokfi <no-reply@nokfi.app>")

# ── Si usas SendGrid ──
# CÓMO CONSEGUIR LA CLAVE:
#   1. Entra en https://signup.sendgrid.com/ y crea una cuenta gratuita
#      (incluye 100 emails/día gratis para siempre)
#   2. Una vez dentro, ve a Settings → Sender Authentication y verifica
#      tu dominio (nokfi.app) o, si aún no tienes dominio, verifica un
#      email individual como remitente temporal
#   3. Ve a Settings → API Keys → Create API Key
#   4. Dale permisos "Full Access" o, si quieres ser más restrictivo,
#      "Restricted Access" con permiso de "Mail Send" únicamente
#   5. Copia la clave (solo se muestra UNA vez) y pégala abajo

SENDGRID_API_KEY=

# ── Si usas Resend (alternativa a SendGrid) ──
# CÓMO CONSEGUIR LA CLAVE:
#   1. Entra en https://resend.com/ y crea una cuenta gratuita
#      (incluye 3.000 emails/mes gratis)
#   2. Ve a Domains y añade/verifica vuestro dominio (nokfi.app)
#   3. Ve a API Keys → Create API Key
#   4. Copia la clave y pégala abajo

RESEND_API_KEY=


# ════════════════════════════════════════════════════════════
# Pagos — Stripe
# ════════════════════════════════════════════════════════════
# CÓMO CONSEGUIR LAS CLAVES:
#   1. Entra en https://dashboard.stripe.com/register y crea una cuenta
#      (te pedirá datos personales/de empresa y datos bancarios para
#      poder cobrar de verdad — puedes rellenarlo más tarde y probar
#      primero en modo "test")
#   2. Una vez dentro del Dashboard, arriba a la derecha hay un toggle
#      "Test mode" / modo real — empieza siempre en modo Test
#   3. Ve a Developers → API keys
#   4. Copia la "Secret key" (empieza por sk_test_... en modo prueba,
#      o sk_live_... en modo real) y pégala en STRIPE_SECRET_KEY
#   5. Para el webhook secret: ve a Developers → Webhooks → Add endpoint
#      - URL del endpoint: https://app.nokfi.app/api/webhooks/stripe
#      - Eventos a escuchar: "checkout.session.completed" y
#        "charge.dispute.created"
#      - Tras crearlo, Stripe te mostrará un "Signing secret" que
#        empieza por whsec_... — pégalo en STRIPE_WEBHOOK_SECRET

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=


# ════════════════════════════════════════════════════════════
# Pagos — PayPal
# ════════════════════════════════════════════════════════════
# CÓMO CONSEGUIR LAS CLAVES:
#   1. Entra en https://developer.paypal.com/ e inicia sesión con una
#      cuenta de PayPal (o crea una nueva, gratis)
#   2. Ve a Dashboard → Apps & Credentials
#   3. Asegúrate de estar en la pestaña "Sandbox" para pruebas (cambia
#      a "Live" solo cuando estéis listos para cobrar de verdad)
#   4. Pulsa "Create App", ponle un nombre (ej. "Nokfi")
#   5. Te mostrará un "Client ID" y un "Secret" — cópialos abajo
#   6. Para el Webhook ID: dentro de la misma app, baja hasta la sección
#      "Webhooks" → Add Webhook
#      - URL: https://app.nokfi.app/api/webhooks/paypal
#      - Eventos a marcar: "Checkout order approved",
#        "Payment capture completed", "Customer dispute created"
#      - Tras crearlo, copia el "Webhook ID" que te muestra

PAYPAL_ENV=sandbox
# Escribe "sandbox" mientras pruebas, y "live" cuando paséis a producción real.

PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=


# ════════════════════════════════════════════════════════════
# Pagos — Revolut Business (Merchant API)
# ════════════════════════════════════════════════════════════
# Comisión más baja que Stripe y PayPal: ~1% + 0,20€ en tarjetas europeas
# de particulares. Requiere abrir una cuenta Revolut Business.
#
# CÓMO CONSEGUIR LAS CLAVES:
#   1. Entra en https://business.revolut.com/signup y crea una cuenta
#      Revolut Business (gratis para el plan básico)
#   2. Completa la verificación de la empresa (datos del negocio, de los
#      socios, documento de identidad)
#   3. Una vez dentro del panel, ve a "APIs" en el menú lateral, y dentro
#      a la pestaña "Merchant API"
#   4. Solicita acceso a una cuenta Merchant si no la tienes activada
#      (puede requerir unos días de revisión la primera vez)
#   5. Genera tu "Secret API key" desde esa misma sección — empieza
#      probando en el entorno Sandbox antes de pasar a producción real
#   6. Para el webhook: dentro de la sección Merchant API, busca
#      "Webhooks" → Add webhook
#      - URL: https://app.nokfi.app/api/webhooks/revolut
#      - Eventos a marcar: "ORDER_COMPLETED", "DISPUTE_ACTION_REQUIRED",
#        "DISPUTE_UNDER_REVIEW"
#      - Tras crearlo, Revolut te mostrará el "signing secret" — pégalo
#        en REVOLUT_WEBHOOK_SIGNING_SECRET

REVOLUT_ENV=sandbox
# Escribe "sandbox" mientras pruebas, y "live" cuando paséis a producción real.

REVOLUT_API_KEY=
REVOLUT_WEBHOOK_SIGNING_SECRET=



# Déjalo vacío por ahora. Cuando lleguéis a esta fase:
#   1. Entra en https://commerce.coinbase.com/ y crea una cuenta
#   2. Ve a Settings → API Keys → Create an API Key
#   3. Para el Webhook Secret: Settings → Webhook subscriptions
#      - URL: https://app.nokfi.app/api/webhooks/coinbase
#      - Te mostrará un "Shared Secret" para verificar las firmas

COINBASE_COMMERCE_API_KEY=
COINBASE_COMMERCE_WEBHOOK_SECRET=
